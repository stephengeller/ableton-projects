# Build output
build/
build-*/
cmake-build-*/
out/

# Wrangler local state (Cloudflare Pages deploy cache)
.wrangler/

# JUCE FetchContent cache lives inside the build dir, but in case of older layouts:
_deps/
JuceLibraryCode/

# IDE
.idea/
.vscode/
*.xcodeproj/
*.xcworkspace/

# macOS
.DS_Store

# Plugin install symlinks (we don't ever check installed binaries in)
*.vst3
*.component

# Distribution tooling — explicitly RE-INCLUDE the dist/ directory so a
# typical user-level global gitignore (~/.gitignore_global) that excludes
# `dist/` (the JS/TS convention) doesn't silently eat our packaging
# scripts. Then re-ignore just the generated zips inside it.
!dist/
!dist/**
dist/output/
