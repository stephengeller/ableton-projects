# Build output
build/
cmake-build-*/
out/

# JUCE FetchContent cache lives inside the build dir, but in case of older layouts:
_deps/
JuceLibraryCode/

# IDE
.idea/
.vscode/
*.xcodeproj/
*.xcworkspace/

# macOS
.DS_Store

# Plugin install symlinks (we don't ever check installed binaries in)
*.vst3
*.component

# Distribution artefacts — generated by dist/package-mac.sh, not committed.
# (The script + INSTALL.md + BUILD-FROM-SOURCE.md ARE committed; only the
# resulting zip and staging directories are not.)
dist/output/
